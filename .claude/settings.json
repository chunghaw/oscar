      "PowerShell(git commit *)", "PowerShell(git log *)", "PowerShell(git branch *)",
      "PowerShell(git switch *)", "PowerShell(git checkout *)", "PowerShell(git restore *)",
      "PowerShell(scripts/codex-review.ps1 *)",
